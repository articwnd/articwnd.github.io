---
import { Image } from 'astro:assets';
import profilePhoto from '../assests/profile.jpeg';
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Richard Xiong"
  description="Richard Xiong - FinTech and Big Data Analytics student, developer, and researcher."
>
  <div class="page">
    <main>
          <p class="eyebrow">articwnd.github.io</p>

      <h1>Richard Xiong</h1>
      <p class="fields">
        Financial Technology
        <span class="op">x</span>
        Big Data Analytics
        <span class="op">x</span>
        Computer Science
        <span class="op">x</span>
        Mathematics
      </p>

      <hr />

      <div class="bio-row">
        <p class="bio">
          Student, developer, and researcher at the intersection of
          <strong>finance and data</strong>. Pursuing a B.S. in Financial
          Technology and Big Data Analytics with minors in Computer Science
          and Mathematics. Currently researching SAFE (Simple Agreement for Future Equity)
          filings to produce a deterministic Loughran-McDonald lexicon scan plus a structured
          LLM-derived rubric score.
        </p>

        <Image
          src={profilePhoto}
          alt="Richard Xiong"
          width={180}
          height={180}
          class="image"
        />
      </div>

      <div class="links">
        <a href="/projects">
          <span class="arr">↗</span> Projects
        </a>
        <a href="https://www.linkedin.com/in/xiongrichard/" target="_blank" rel="noopener noreferrer">
          <span class="arr">↗</span> LinkedIn
        </a>
        <a href="https://github.com/articwnd" target="_blank" rel="noopener noreferrer">
          <span class="arr">↗</span> GitHub
        </a>
      </div>
    </main>
  </div>
</Layout>

<style>
  .page {
    background: var(--bg);
    color: var(--primary);
    font-family: 'Space Grotesk', sans-serif;
    min-height: 100vh;
  }

  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 80px 40px;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 40px;
    opacity: 0.8;
  }

  h1 {
    font-size: clamp(40px, 8vw, 64px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--primary);
    margin-bottom: 20px;
  }

  .fields {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 40px;
    line-height: 2.2;
  }

  .op {
    color: var(--accent);
    margin: 0 8px;
  }

  hr {
    border: none;
    border-top: 1px solid var(--border);
    margin-bottom: 40px;
  }

  .bio-row {
    display: flex;
    align-items: flex-start;
    gap: 40px;
    margin-bottom: 48px;
  }

  .bio {
    font-size: 16px;
    line-height: 1.8;
    color: var(--muted);
    flex: 1;
  }

  .bio strong {
    color: var(--primary);
    font-weight: 500;
  }

  .links {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
  }

  .links a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--primary);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    padding-bottom: 2px;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .links a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .arr { color: var(--accent); }

  .her {
    display: flex;
    align-items: flex-start;
    gap: 40px;
  }

  .image {
    flex-shrink: 0;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--border);
  }

  .hero-text {
    flex: 1;
    min-width: 0;
  }

  @media (max-width: 640px) {
    main { padding: 48px 24px; }
    .fields { font-size: 11px; }
    .bio-row {
      flex-direction: column;
      align-items: center;
    }
    .links {
      justify-content: center;
    }
  }
</style>

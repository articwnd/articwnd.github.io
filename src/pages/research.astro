---
import Layout from '../layouts/Layout.astro';

// change status from "soon" to "published" when a chapter is ready
// the href must match the filenameyou create in src/pages/research/.

const chapters = [
    {
        number: 1,
        title: "How to Read a Market Claim",
        description: "Before a single chart or strategy, you need a filter for what counts as evidence. " + 
        "This chapter rebuilds how you judge any market claim, so 'it worked in a backtest' stops passing as proof. " +
        "You leave able to tell a real pattern from a good story, which is the skill every later chapter depends on.",
        href: "research/chapter-1",
        status: "soon",
    },
    {
        number: 2,
        title: "The Macro Machine",
        description: "Markets don't rise because the economy is 'good.'' They move on interest rates, " +
        "inflation surprises, the dollar, and liquidity, relative to what was already expected. This chapter maps those " +
        "forces and why 'already priced in' explains most of what looks surprising, worked through the 2022 to 2023 rate cycle.",
        href: "research/chapter-2",
        status: "soon",
    },
    {
        number: 3,
        title: "Reading Price Without Fooling Yourself",
        description: "Candlesticks and chart patterns, taught honestly. You learn what each pattern claims and the market " +
        "psychology behind it, then see what happens when you actually measure it. You walk out treating a pattern as a hypothesis " +
        "with a hit rate, not a rule to obey.",
        href: "research/chapter-3",
        status: "soon",
    },
    {
        number: 4,
        title: "From Idea to Tested System",
        description: "Where reading the market turns into researching it. This chapter shows how a trading idea becomes something " +
        "you can trust: building a signal, running a backtest as a real experiment, and avoiding the traps (overfitting, testing too many things) " +
        "that make good-looking results meaningless. Includes code you can re-run yourself.",
        href: "research/chapter-4",
        status: "soon",
    },
    {
        number: 5,
        title: "Risk, Sizing, and Surviving Yourself",
        description: "A genuine edge still bleeds out if you size it wrong, misread correlation, or let your own instincts drive. This " +
        "chapter covers position sizing, what a drawdown is really diagnosing, and the behavioral mistakes (cutting winners early, chasing losses) " +
        "that quietly end accounts.",
        href: "research/chapter-5",
        status: "soon",
    },
    {
        number: 6,
        title: "One Idea, End to End",
        description: "A single research question taken through the entire cycle: hypothesis, signal, validation, costs, sizing, and an honest " +
        "verdict, with the full repository open to inspect. The point is not a guaranteed winner. It is showing the process that separates a real " +
        "result from a lucky one.",
        href: "research/chapter-6",
        status: "soon",
    },
]

---

<Layout title="Research — Richard Xiong">
  <main class="research">
    <p class="page-header">
      <h1>Start Here</h1>
      <p class="tagline">
        The newest article isn't the best place to start. Each chapter builds on foundations helpful for the next.
        Chapters 1-3 are designed for beginners, and chapter 4-6 focus on more technical ideas.
      </p>
    </p>

    <p class="intro">
      [A short paragraph explaining what this research series is about, who
      it is for, and why you structured it this way. The aligrithm site
      opens with "the newest article is the worst place to start" — your
      version should orient the reader in the same direct way. 3-5 sentences.]
    </p>

    <p class="intro">
      [Optional second paragraph. What will readers know by the end? What
      gap in the existing literature or practice are you addressing?]
    </p>

    <div class="chapter-list">
      {chapters.map((ch) => (
        ch.status === "published" ? (
          <a href={ch.href} class="chapter-card clickable">
            <span class="chapter-number">{String(ch.number).padStart(2, '0')}</span>
            <div class="chapter-body">
              <h2>{ch.title}</h2>
              <p>{ch.description}</p>
            </div>
            <span class="chapter-arrow">→</span>
          </a>
        ) : (
          <div class="chapter-card">
            <span class="chapter-number">{String(ch.number).padStart(2, '0')}</span>
            <div class="chapter-body">
              <h2>{ch.title}</h2>
              <p>{ch.description}</p>
            </div>
            <span class="chapter-soon">Soon</span>
          </div>
        )
      ))}
    </div>

  </main>
</Layout>

<style>
  .research {
    max-width: 700px;
    margin: 0 auto;
    padding: 120px 40px 80px;
  }

  h1 {
    font-size: clamp(32px, 6vw, 48px);
    margin-bottom: 32px;
  }

  .page-header {
    margin-bottom: 32px;
  }

  .tagline {
    font-size: 17px;
    line-height: 1.6;
    color: var(--muted);
    margin-top: 12px;
    margin-bottom: 24px;
  }

  .intro {
    font-size: 16px;
    line-height: 1.85;
    color: var(--muted);
    margin-bottom: 24px;
  }

  .chapter-list {
    margin-top: 56px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .chapter-card {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 28px 24px;
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--primary);
    text-decoration: none;
    transition: border-color 0.15s ease;
  }

  .chapter-card.clickable:hover {
    border-color: var(--accent);
    cursor: pointer;
  }

  .chapter-card:not(.clickable) {
    opacity: 0.5;
    cursor: default;
  }

  .chapter-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 28px;
    font-weight: 500;
    color: var(--accent);
    opacity: 0.4;
    min-width: 40px;
    line-height: 1;
    flex-shrink: 0;
  }

  .chapter-card.clickable .chapter-number {
    opacity: 1;
  }

  .chapter-body {
    flex: 1;
    min-width: 0;
  }

  .chapter-body h2 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 6px;
    color: var(--primary);
  }

  .chapter-body p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--muted);
  }

  .chapter-arrow {
    font-size: 18px;
    color: var(--accent);
    flex-shrink: 0;
  }

  .chapter-soon {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 3px 8px;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .research { padding: 100px 24px 60px; }
    .chapter-number { font-size: 20px; }
    .chapter-card { gap: 16px; padding: 20px 16px; }
  }
</style>
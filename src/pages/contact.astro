---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Richard Xiong">
    <main class="page-content">
        <h1>Contact</h1>
        <p class="subtitlte">
            Have a question, opportunity, or just want to connect? Send
            me a message and I'll get back to you as soon as I can.
        </p>

        <form action="https://api.web3forms.com/submit" method="POST">
            <input type="hidden" name="access_key" value="c2bff92f-08d0-4790-921f-d05d4a7e4637" />

            <input type="checkbox" name="botcheck" style="display:none" />

            <input type="hidden" name="subject" value="New message from articwnd.github.io" />

            <div class="field">
                <label for="name">Name</label>
                <input
                    type="text"
                    id="name"
                    name="name"
                    placeholder="Your Name"
                    required
                />
            </div>

            <div class="field">
                <label for="email">Email</label>
                <input
                    type="email"
                    id="email"
                    name="email"
                    placeholder="your@email.com"
                    required
                />
            </div>

            <div class="field">
                <label for="message">Message</label>
                <textarea
                    id="message"
                    name="message"
                    rows="6"
                    placeholder="What's on your mind?"
                    required
                ></textarea>
            </div>

            <button type="submit" id="submit-btn">Send Message</button>

            <p id="form-status" class="status" aria-live="polite"></p>
        </form>
    </main>
</Layout>

<style>
  .contact {
    max-width: 600px;
    margin: 0 auto;
    padding: 120px 40px 80px;
  }

  h1 {
    font-size: clamp(32px, 6vw, 48px);
    margin-bottom: 16px;
  }

  .subtitle {
    font-size: 16px;
    line-height: 1.7;
    color: var(--muted);
    margin-bottom: 48px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 24px;
  }

  label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }

  input,
  textarea {
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 12px 16px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    color: var(--primary);
    outline: none;
    transition: border-color 0.15s ease;
    width: 100%;
    resize: vertical;
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--muted);
    opacity: 0.6;
  }

  input:focus,
  textarea:focus {
    border-color: var(--accent);
  }

  button {
    margin-top: 8px;
    padding: 12px 28px;
    background: transparent;
    border: 1px solid var(--accent);
    border-radius: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.05em;
    color: var(--accent);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  button:hover:not(:disabled) {
    background: var(--accent);
    color: var(--bg);
  }

  button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .status {
    margin-top: 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
  }

  .status.success { color: #4ade80; }
  .status.error   { color: #f87171; }

  @media (max-width: 640px) {
    .contact { padding: 100px 24px 60px; }
  }
</style>